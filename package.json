{
  "name": "@uniswap/v2-core",
  "description": "Build UniswapV2 with Solidity 0.8.x Modern EVM",
  "version": "2.0.0",
  "homepage": "https://uniswap.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/islishude/uniswapv2-solc0.8"
  },
  "keywords": [
    "uniswap",
    "ethereum",
    "v2",
    "core",
    "uniswap-v2"
  ],
  "files": [
    "contracts",
    "!contracts/test",
    "typechain-types",
    "!typechain-types/test",
    "artifacts/contracts",
    "!artifacts/test",
    "!artifacts/contracts/**/*.dbg.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^1.1.1",
    "@typechain/ethers-v6": "^0.4.3",
    "@typechain/hardhat": "^8.0.3",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "chai": "^4.5.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^1.4.3",
    "solhint": "^4.5.4",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "lint": "prettier --plugin=prettier-plugin-solidity --check src 'contracts/**/*.sol' && solhint 'contracts/**/*.sol'",
    "lint:fix": "prettier --plugin=prettier-plugin-solidity --write src 'contracts/**/*.sol'",
    "clean": "rimraf artifacts cache types",
    "precompile": "pnpm run clean",
    "compile": "hardhat compile",
    "build": "pnpm run compile",
    "test": "hardhat test",
    "prepublishOnly": "pnpm run test"
  },
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@8.12.0",
  "prettier": {
    "trailingComma": "all"
  }
}
