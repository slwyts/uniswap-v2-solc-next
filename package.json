{
  "name": "@uniswap/v2-core",
  "description": "Build UniswapV2 with Solidity 0.8.x Modern EVM",
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://uniswap.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/islishude/uniswapv2-solc0.8"
  },
  "keywords": [
    "uniswap",
    "ethereum",
    "v2",
    "core",
    "uniswap-v2"
  ],
  "files": [
    "contracts",
    "!contracts/test",
    "types/ethers-contracts",
    "!types/ethers-contracts/test",
    "artifacts/contracts",
    "!artifacts/test",
    "!artifacts/contracts/**/*.dbg.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.3",
    "@nomicfoundation/hardhat-ignition": "^3.1.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-keystore": "^3.0.5",
    "@nomicfoundation/hardhat-mocha": "^3.0.14",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
    "@nomicfoundation/hardhat-typechain": "^3.0.4",
    "@nomicfoundation/hardhat-verify": "^3.0.12",
    "@nomicfoundation/ignition-core": "^3.1.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "chai": "^6.2.2",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "ethers": "^6.16.0",
    "hardhat": "^3.2.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.3.1",
    "rimraf": "^6.1.3",
    "solhint": "^6.1.0",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "lint": "prettier --plugin=prettier-plugin-solidity --check src 'contracts/**/*.sol' && solhint 'contracts/**/*.sol'",
    "lint:fix": "prettier --plugin=prettier-plugin-solidity --write src 'contracts/**/*.sol'",
    "clean": "rimraf artifacts cache types typechain-types",
    "precompile": "pnpm run clean",
    "compile": "hardhat compile",
    "build": "pnpm run compile",
    "test": "hardhat test",
    "prepublishOnly": "pnpm run test"
  },
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@10.32.1",
  "prettier": {
    "trailingComma": "all"
  }
}
